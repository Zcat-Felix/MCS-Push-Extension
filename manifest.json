{
  "manifest_version": 3,
  "name": "美云销图片下载器",
  "version": "3.2",
  "description": "美云销商品图片与参数的收集工具，支持自动分类打包和派发到京东秒送、美团闪购",
  "author": "Marvis",
  "permissions": [
    "downloads",
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "*://*.midea.com/*",
    "*://*.smartmidea.net/*",
    "*://signin.midea.com/*",
    "*://sales.midea.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "美云销图片下载器",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.midea.com/*",
        "*://signin.midea.com/*",
        "*://sales.midea.com/*",
        "*://*.smartmidea.net/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/mcsp-logo-lightblue.png", "icons/mt-icon.png", "icons/jd-icon.png"],
      "matches": ["*://*.midea.com/*", "*://signin.midea.com/*", "*://sales.midea.com/*", "*://*.smartmidea.net/*"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}